<!-- ============================================================
     Practical 10 - Student Details XML + XSD Schema Validation
     ============================================================
     File: students.xml
     Root element: student_details
     Each student has: reg no (attribute), name (first+last grouped),
     department, address, phone (XXX-XXXX format)
     ============================================================ -->

<?xml version="1.0" encoding="UTF-8"?>
<student_details xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                 xsi:noNamespaceSchemaLocation="students.xsd">

